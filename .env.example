DEBUG=true
SECRET_KEY=change-me-in-local-dev
FERNET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HTTP_PORT=80

DB_ENGINE=mysql
DB_NAME=cardshop
DB_USER=cardshop
DB_PASSWORD=cardshop_dev_password
MYSQL_ROOT_PASSWORD=root-password
DB_HOST=127.0.0.1
DB_PORT=3306
REDIS_URL=redis://127.0.0.1:6379/0

LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
SLOW_REQUEST_MS=1000

SITE_URL=http://localhost:5173
PAYMENT_PROVIDER=dev
EASYPAY_PID=
EASYPAY_KEY=
EASYPAY_GATEWAY_URL=

# QQ 邮箱 SMTP。真实使用时填 QQ 邮箱授权码，不填 QQ 登录密码。
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# 支付宝沙箱。开启时设置 PAYMENT_PROVIDER=alipay 并填写下面三项。
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
