DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
FERNET_KEY=
ALLOWED_HOSTS=your-domain.example.com
CSRF_TRUSTED_ORIGINS=https://your-domain.example.com
CORS_ALLOWED_ORIGINS=https://your-domain.example.com
HTTP_PORT=80

DB_ENGINE=mysql
DB_NAME=cardshop
DB_USER=cardshop
DB_PASSWORD=replace-with-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-strong-mysql-root-password
DB_HOST=mysql
DB_PORT=3306
REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_DIR=/app/logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
SLOW_REQUEST_MS=1000

SITE_URL=https://your-domain.example.com
PAYMENT_PROVIDER=alipay

# QQ 邮箱 SMTP。EMAIL_HOST_PASSWORD 填 QQ 邮箱授权码。
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=your-qq-number@qq.com
EMAIL_HOST_PASSWORD=replace-with-qq-mail-authorization-code
DEFAULT_FROM_EMAIL=your-qq-number@qq.com

# 支付宝沙箱；生产时替换为正式 app_id、私钥、公钥和网关。
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-domain.example.com/api/payments/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.example.com/orders

EASYPAY_PID=
EASYPAY_KEY=
EASYPAY_GATEWAY_URL=
